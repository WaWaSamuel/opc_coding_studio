# ===== Model (F-F.1 Model Adapter) =====
# provider: mock(离线,默认) | ark(豆包)
MODEL_PROVIDER=mock
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
ARK_MODEL_SMALL=
ARK_TIMEOUT_SECONDS=300

# ===== Persistence (F-F.2) =====
DB_PATH=./data/app.db

# ===== Cost Guard (F-D.6 成本熔断) =====
SOFT_TASK_TOKENS=50000
HARD_TASK_TOKENS=100000
MAX_DAILY_TOKENS=2000000

# ===== Reliability (F-D.3) =====
MAX_SELF_REPAIR=3
MAX_API_OVERLOAD_RETRY=3

# ===== M3 Harness (F-D.2 节点重试 / M07 全局熔断 / F-C 记忆与检索) =====
# 节点重试:瞬时失败(模型 5xx/限流/JSON 自修复仍失败)原地重试上限,与业务回退独立计数
MAX_NODE_RETRY=3
# 业务回退(Loop/Rework)上限,超限置 need_decision 等 Host 拍板
MAX_LOOP_ITERATIONS=3
# 连续 Compact 失败上限 → 熔断,停压缩保留原文并告警 Host
MAX_COMPACT_FAILURES=3
# 任务记忆超此 token 阈值触发全量(九段)压缩
COMPACT_TRIGGER_TOKENS=8000
# 大产出落库后 prompt 内保留的预览字节数(超出走 demand-paging 指针)
RESULT_PREVIEW_BYTES=2048
# 检索式记忆注入 Top-K
RETRIEVE_TOP_K=3

# ===== Gateway 飞书入口 (M01 / F-A.2,M4) =====
# 长连接(出站 WebSocket)无需公网回调/内网穿透;仅企业自建应用支持。
# 飞书开发者后台:开启机器人能力 + 事件订阅选"长连接模式" + 订阅 im.message.receive_v1
# + 权限 im:message / im:message.p2p_msg:readonly。
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DOMAIN=https://open.feishu.cn
# 仅接受该 Host(open_id)的指令(身份校验);留空则不限制(本地调试)。
LARK_BOT_TARGET_OPEN_ID=

# ===== API 服务 (M4 入口层 / 界面) =====
API_HOST=0.0.0.0
API_PORT=8001
CORS_ALLOW_ORIGINS=*
