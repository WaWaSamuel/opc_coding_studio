# 一人公司 AI Agent 系统 — 环境变量样例(docker-compose env_file 读根目录 .env)
# 用法:cp .env.example .env 后填入真实密钥。真实 .env 已 gitignore,绝不入库。

# ===== Model (F-F.1 Model Adapter) =====
# provider: mock(离线,默认) | ark(豆包)
MODEL_PROVIDER=mock
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=
ARK_MODEL_SMALL=
ARK_TIMEOUT_SECONDS=300

# ===== Persistence (F-F.2) =====
# 容器内固定 /app/data/app.db(compose 已注入并挂载 ./data);本地裸跑用相对路径。
DB_PATH=./data/app.db

# ===== Cost Guard (F-D.6 成本熔断) =====
SOFT_TASK_TOKENS=50000
HARD_TASK_TOKENS=100000
MAX_DAILY_TOKENS=2000000

# ===== Reliability (F-D.3 / F-D.2 / M07 熔断常量表) =====
MAX_SELF_REPAIR=3
MAX_API_OVERLOAD_RETRY=3
MAX_NODE_RETRY=3
MAX_LOOP_ITERATIONS=3
MAX_COMPACT_FAILURES=3

# ===== Context / Memory (F-C.3/C.5) =====
COMPACT_TRIGGER_TOKENS=8000
RESULT_PREVIEW_BYTES=2048
RETRIEVE_TOP_K=3

# ===== Gateway 飞书入口 (M01 / F-A.2,M4) =====
# 长连接(出站 WebSocket)无需公网回调/内网穿透;仅企业自建应用支持。
# 飞书开发者后台:开启机器人能力 + 事件订阅选"长连接模式" + 订阅 im.message.receive_v1
# + 权限 im:message / im:message.p2p_msg:readonly;need_decision 卡片按钮需订阅 card.action.trigger。
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DOMAIN=https://open.feishu.cn
# 仅接受该 Host(open_id)的指令(身份校验);留空则不限制(本地调试)。
LARK_BOT_TARGET_OPEN_ID=
# 设为 0 可在有凭据时仍只起 Web 渠道(不连飞书)。
OPC_ENABLE_LARK=1

# ===== Git Tool (M09,M5 接入) =====
GITHUB_TOKEN=

# ===== API 服务 (M4 入口层 / 界面) =====
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*
